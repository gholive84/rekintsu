Options -Indexes
DirectoryIndex index.php index.html

RewriteEngine On

# Protege install.php de acesso externo após instalação
# RewriteRule ^cms/install\.php$ - [F,L]

# Guideline interno (sem indexação)
RewriteRule ^guideline/?$ site/paginas/guideline.php [L]

# Blog
RewriteRule ^blog/?$ site/paginas/blog.php [L]
RewriteRule ^blog/([a-zA-Z0-9_-]+)/?$ site/paginas/post.php?slug=$1 [L,QSA]

# Páginas internas
RewriteRule ^sobre-a-clinica/?$ site/paginas/sobre-a-clinica.php [L]
RewriteRule ^como-funciona/?$ site/paginas/como-funciona.php [L]
RewriteRule ^pilates-gestantes/?$ site/paginas/pilates-gestantes.php [L]
RewriteRule ^pilates-hernias-lesoes/?$ site/paginas/pilates-hernias-lesoes.php [L]
RewriteRule ^pilates-idosos/?$ site/paginas/pilates-idosos.php [L]
RewriteRule ^pilates-pos-cirurgico/?$ site/paginas/pilates-pos-cirurgico.php [L]
