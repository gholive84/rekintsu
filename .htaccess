Options -Indexes
DirectoryIndex index.php index.html

RewriteEngine On

# CMS — acesso via /cms (pasta real, sem rewrite necessário)
# Protege install.php de acesso externo após instalação (descomente após instalar)
# RewriteRule ^cms/install\.php$ - [F,L]

# Blog
RewriteRule ^blog/?$ blog/index.php [L]

# Guideline interno (sem indexação)
RewriteRule ^guideline/?$ site/paginas/guideline.php [L]

# Páginas internas de serviços
RewriteRule ^projetos-wordpress-premium/?$ site/paginas/projetos-wordpress-premium.php [L]
RewriteRule ^sites-ia/?$ site/paginas/sites-ia.php [L]
RewriteRule ^suporte-wordpress-premium/?$ site/paginas/suporte-wordpress-premium.php [L]
